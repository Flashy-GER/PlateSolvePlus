<ResourceDictionary
    x:Class="NINA.Plugins.PlateSolvePlus.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugins.PlateSolvePlus.SecondaryAutofocus.Models">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Converters/Converters.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- =========================================
         Shared styles
         ========================================= -->
    <Style x:Key="FormRowLabel" TargetType="{x:Type TextBlock}">
        <Setter Property="Width" Value="220"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="FormRow" TargetType="{x:Type StackPanel}">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="HelpCard" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#33000000"/>
        <Setter Property="Background" Value="#11000000"/>
    </Style>

    <!-- =========================================
         Options Template
         ========================================= -->
    <DataTemplate x:Key="PlateSolvePlus_Options">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <Grid Margin="10" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="560"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- =======================
                     LEFT COLUMN (SETTINGS)
                     ======================= -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Left">

                    <TextBlock Text="PlateSolvePlus – Guide Scope Plate Solving"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <!-- ========== Camera Settings ========== -->
                    <GroupBox Header="Capture Settings" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Exposure (s)"
                                           ToolTip="Exposure time of the guide / secondary camera used for plate solving."/>
                                <TextBox Width="140"
                                         ToolTip="Seconds, e.g. 1.5"
                                         Text="{Binding Settings.GuideExposureSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Gain"
                                           ToolTip="Gain of the secondary camera."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 0..300 or -1 (if supported)"
                                         Text="{Binding Settings.GuideGain, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Binning"
                                           ToolTip="Binning of the secondary camera (typically 1 or 2)."/>
                                <TextBox Width="140"
                                         ToolTip="Integer ≥ 1"
                                         Text="{Binding Settings.GuideBinning, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!-- ========== Optics / Scale ========== -->
                    <GroupBox Header="Optics / Scale" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Focal Length (mm)"
                                           ToolTip="Focal length of the guide / secondary setup (important for pixel scale and solver parameters)."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 240"
                                         Text="{Binding Settings.GuideFocalLengthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <CheckBox Content="Use camera pixel size"
                                      Margin="0,0,0,8"
                                      ToolTip="If enabled: pixel size is taken from the camera/profile. Otherwise enter manually below."
                                      IsChecked="{Binding Settings.UseCameraPixelSize, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Pixel Size (µm)"
                                           ToolTip="Only relevant when 'Use camera pixel size' is disabled."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 3.75"
                                         Text="{Binding Settings.GuidePixelSizeUm, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Style>
                                        <Style TargetType="{x:Type TextBox}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.UseCameraPixelSize}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!-- ========== Solver ========== -->
                    <GroupBox Header="Solver" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Search Radius (°)"
                                           ToolTip="Search radius around the start coordinates. Larger = more robust but slower."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 5"
                                         Text="{Binding Settings.SolverSearchRadiusDeg, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Downsample"
                                           ToolTip="Downsample factor for the solver (e.g. 2 = faster)."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 2"
                                         Text="{Binding Settings.SolverDownsample, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Timeout (s)"
                                           ToolTip="Maximum time per solve attempt."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 60"
                                         Text="{Binding Settings.SolverTimeoutSec, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!-- ========== Centering ========== -->
                    <GroupBox Header="Centering" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Threshold (arcmin)"
                                           ToolTip="Target accuracy: maximum remaining error in arcminutes."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 1.0"
                                         Text="{Binding Settings.CenteringThresholdArcmin, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Max attempts"
                                           ToolTip="Maximum number of iterations (solve → correction → slew/sync)."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 5"
                                         Text="{Binding Settings.CenteringMaxAttempts, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!-- ========== Offset ========== -->
                    <GroupBox Header="Offset (Secondary → Main)" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding OffsetStatusText}"/>

                            <Separator Margin="0,6"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="180" Text="Rotation (quaternion):"/>
                                <TextBlock Text="{Binding OffsetQuaternionText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Width="180" Text="Rotation angle:"/>
                                <TextBlock Text="{Binding OffsetRotationDegText}"/>
                            </StackPanel>

                            <Separator Margin="0,6"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="180" Text="ΔRA:"/>
                                <TextBlock Text="{Binding OffsetRaArcsecText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Width="180" Text="ΔDec:"/>
                                <TextBlock Text="{Binding OffsetDecArcsecText}"/>
                            </StackPanel>

                            <Separator Margin="0,6"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="180" Text="Last calibrated:"/>
                                <TextBlock Text="{Binding OffsetLastCalibratedText}"/>
                            </StackPanel>

                            <Button Content="Reset offset"
                                    Command="{Binding ResetOffsetCommand}"
                                    Margin="0,10,0,0"
                                    ToolTip="Fully resets rotation and offset values."/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ========== Touch-N-Stars / Local API ========== -->
                    <GroupBox Header="Touch-N-Stars / Local API" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <CheckBox Content="Enable local API"
                                      ToolTip="Starts a local API host (trigger/results/preview for Touch-N-Stars)."
                                      IsChecked="{Binding Settings.ApiEnabled, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Style="{StaticResource FormRow}" Margin="0,10,0,0">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="Port"
                                           ToolTip="TCP port of the API host (e.g. 1899)."/>
                                <TextBox Width="140"
                                         ToolTip="e.g. 17890"
                                         Text="{Binding Settings.ApiPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <CheckBox Content="Secure API access with token"
                                      Margin="0,6,0,0"
                                      ToolTip="If enabled, requests must include a valid token."
                                      IsChecked="{Binding Settings.ApiRequireToken, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Style="{StaticResource FormRow}" Margin="0,8,0,0">
                                <TextBlock Style="{StaticResource FormRowLabel}"
                                           Text="API token"
                                           ToolTip="Authentication token (only used if token protection is enabled)."/>
                                <TextBox Width="280"
                                         ToolTip="Only used when token protection is enabled."
                                         Text="{Binding Settings.ApiToken, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                </StackPanel>

                <!-- =======================
                     RIGHT COLUMN (HELP)
                     ======================= -->
                <StackPanel Grid.Column="2">

                    <TextBlock Text="Help / Notes"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock Text="Capture Settings" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap">
                                Capture settings for the secondary camera used for plate solving.
                                Shorter exposures are faster but less robust for faint stars.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock Text="Optics / Scale" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap">
                                Focal length and pixel size affect pixel scale and solver performance.
                                Prefer using pixel size from the camera profile if possible.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock Text="Solver" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap">
                                A larger search radius increases tolerance but slows solving.
                                Downsample 2 is usually a good compromise.
                                Timeout protects against solver stalls.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock Text="Offset" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap">
                                The currently calibrated offset can be viewed here. 
                                The offset must be reset before recalibration.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock Text="Local API (Touch-N-Stars)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap">
                                Enables a local HTTP server (localhost).
                                Change the port if there are conflicts.
                                Only enable token protection if access needs to be secured.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <GroupBox Header="OAG Autofocus" Margin="0,10,0,0">
                        <StackPanel>
                        <CheckBox Content="Show AF block in Camera UI"
                                      Margin="0,0,0,10"
                                      ToolTip="Shows/hides the Autofocus (AFBlock) section in the Camera dockable."
                                      IsChecked="{Binding Settings.AFBlock, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Capture" FontWeight="SemiBold" Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Exposure (s)" Width="150"/>
                                <TextBox Width="80"
                                         Text="{Binding Settings.SecondaryAutofocus.ExposureSeconds,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Gain" Width="150"/>
                                <TextBox Width="80"
                                         Text="{Binding Settings.SecondaryAutofocus.Gain,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Bin X / Y" Width="150"/>
                                <TextBox Width="38" Margin="0,0,6,0"
                                         Text="{Binding Settings.SecondaryAutofocus.BinX,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Width="38"
                                         Text="{Binding Settings.SecondaryAutofocus.BinY,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <Separator Margin="0,8,0,8"/>

                            <TextBlock Text="Focus sweep" FontWeight="SemiBold" Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Step size" Width="150"/>
                                <TextBox Width="80"
                                         Text="{Binding Settings.SecondaryAutofocus.StepSize,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Steps out / in" Width="150"/>
                                <TextBox Width="38" Margin="0,0,6,0"
                                         Text="{Binding Settings.SecondaryAutofocus.StepsOut,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Width="38"
                                         Text="{Binding Settings.SecondaryAutofocus.StepsIn,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <Separator Margin="0,8,0,8"/>

                            <TextBlock Text="Backlash" FontWeight="SemiBold" Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Backlash steps" Width="150"/>
                                <TextBox Width="80"
                                         Text="{Binding Settings.SecondaryAutofocus.BacklashSteps,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Mode" Width="150"/>
                            <ComboBox Width="200"
                                      SelectedValue="{Binding Settings.SecondaryAutofocus.BacklashMode,
                                                              UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="None" Tag="{x:Static local:BacklashMode.None}"/>
                                <ComboBoxItem Content="Overshoot + Return" Tag="{x:Static local:BacklashMode.OvershootReturn}"/>
                                <ComboBoxItem Content="One-way approach" Tag="{x:Static local:BacklashMode.OneWayApproach}"/>
                            </ComboBox>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                </StackPanel>

            </Grid>
        </ScrollViewer>
    </DataTemplate>
</ResourceDictionary>
