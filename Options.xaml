<ResourceDictionary
    x:Class="NINA.Plugins.PlateSolvePlus.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:psp="clr-namespace:NINA.Plugins.PlateSolvePlus">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Converters/Converters.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        =========================================
        Shared styles
        =========================================
    -->
    <Style x:Key="FormRowLabel" TargetType="{x:Type TextBlock}">
        <Setter Property="Width" Value="220" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <Style x:Key="FormRow" TargetType="{x:Type StackPanel}">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="HelpCard" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#33000000" />
        <Setter Property="Background" Value="#11000000" />
    </Style>

    <!--
        =========================================
        Options Template
        =========================================
    -->
    <DataTemplate x:Key="PlateSolvePlus_Options">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <Grid Margin="10" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="560" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--
                    =======================
                    LEFT COLUMN (SETTINGS)
                    =======================
                -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Left">

                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="PlateSolvePlus – Guide Scope Plate Solving" />

                    <!--  ========== Camera Settings ==========  -->
                    <GroupBox Margin="0,0,0,10" Header="Capture Settings">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Exposure (s)"
                                    ToolTip="Exposure time of the guide / secondary camera used for plate solving." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.GuideExposureSeconds, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="Seconds, e.g. 1.5" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Gain"
                                    ToolTip="Gain of the secondary camera." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.GuideGain, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 0..300 or -1 (if supported)" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Binning"
                                    ToolTip="Binning of the secondary camera (typically 1 or 2)." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.GuideBinning, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="Integer ≥ 1" />
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!--  ========== Optics / Scale ==========  -->
                    <GroupBox Margin="0,0,0,10" Header="Optics / Scale">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Focal Length (mm)"
                                    ToolTip="Focal length of the guide / secondary setup (important for pixel scale and solver parameters)." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.GuideFocalLengthMm, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 240" />
                            </StackPanel>

                            <CheckBox
                                Margin="0,0,0,8"
                                Content="Use camera pixel size"
                                IsChecked="{Binding Settings.UseCameraPixelSize, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="If enabled: pixel size is taken from the camera/profile. Otherwise enter manually below." />

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Pixel Size (µm)"
                                    ToolTip="Only relevant when 'Use camera pixel size' is disabled." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.GuidePixelSizeUm, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 3.75">
                                    <TextBox.Style>
                                        <Style TargetType="{x:Type TextBox}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.UseCameraPixelSize}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Setter Property="Opacity" Value="0.6" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!--  ========== Solver ==========  -->
                    <GroupBox Margin="0,0,0,10" Header="Solver">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Search Radius (°)"
                                    ToolTip="Search radius around the start coordinates. Larger = more robust but slower." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.SolverSearchRadiusDeg, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 5" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Downsample"
                                    ToolTip="Downsample factor for the solver (e.g. 2 = faster)." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.SolverDownsample, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 2" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Timeout (s)"
                                    ToolTip="Maximum time per solve attempt." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.SolverTimeoutSec, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 60" />
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!--  ========== Centering ==========  -->
                    <GroupBox Margin="0,0,0,10" Header="Centering">
                        <StackPanel Margin="10">

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Threshold (arcmin)"
                                    ToolTip="Target accuracy: maximum remaining error in arcminutes." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.CenteringThresholdArcmin, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 1.0" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Max attempts"
                                    ToolTip="Maximum number of iterations (solve → correction → slew/sync)." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.CenteringMaxAttempts, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 5" />
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                    <!--  ========== Offset ==========  -->
                    <GroupBox Margin="0,0,0,10" Header="Offset (Secondary → Main)">
                        <StackPanel Margin="10">

                            <TextBlock FontWeight="SemiBold" Text="{Binding OffsetStatusText}" />

                            <Separator Margin="0,6" />

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="180" Text="Rotation (quaternion):" />
                                <TextBlock Text="{Binding OffsetQuaternionText}" />
                            </StackPanel>

                            <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                <TextBlock Width="180" Text="Rotation angle:" />
                                <TextBlock Text="{Binding OffsetRotationDegText}" />
                            </StackPanel>

                            <Separator Margin="0,6" />

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="180" Text="ΔRA:" />
                                <TextBlock Text="{Binding OffsetRaArcsecText}" />
                            </StackPanel>

                            <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                <TextBlock Width="180" Text="ΔDec:" />
                                <TextBlock Text="{Binding OffsetDecArcsecText}" />
                            </StackPanel>

                            <Separator Margin="0,6" />

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="180" Text="Last calibrated:" />
                                <TextBlock Text="{Binding OffsetLastCalibratedText}" />
                            </StackPanel>

                            <Button
                                Margin="0,10,0,0"
                                Command="{Binding ResetOffsetCommand}"
                                Content="Reset offset"
                                ToolTip="Fully resets rotation and offset values." />
                        </StackPanel>
                    </GroupBox>

                    <!--  ========== Touch-N-Stars / Local API ==========  -->
                    <GroupBox Margin="0,0,0,10" Header="Touch-N-Stars / Local API">
                        <StackPanel Margin="10">

                            <CheckBox
                                Content="Enable local API"
                                IsChecked="{Binding Settings.ApiEnabled, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Starts a local API host (trigger/results/preview for Touch-N-Stars)." />

                            <StackPanel Margin="0,10,0,0" Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="Port"
                                    ToolTip="TCP port of the API host (e.g. 1899)." />
                                <TextBox
                                    Width="140"
                                    Text="{Binding Settings.ApiPort, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="e.g. 17890" />
                            </StackPanel>

                            <CheckBox
                                Margin="0,6,0,0"
                                Content="Secure API access with token"
                                IsChecked="{Binding Settings.ApiRequireToken, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="If enabled, requests must include a valid token." />

                            <StackPanel Margin="0,8,0,0" Style="{StaticResource FormRow}">
                                <TextBlock
                                    Style="{StaticResource FormRowLabel}"
                                    Text="API token"
                                    ToolTip="Authentication token (only used if token protection is enabled)." />
                                <TextBox
                                    Width="280"
                                    Text="{Binding Settings.ApiToken, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="Only used when token protection is enabled." />
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                </StackPanel>

                <!--
                    =======================
                    RIGHT COLUMN (HELP)
                    =======================
                -->
                <StackPanel Grid.Column="2">

                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Help / Notes" />

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Capture Settings" />
                            <TextBlock TextWrapping="Wrap">
                                Capture settings for the secondary camera used for plate solving.
                                Shorter exposures are faster but less robust for faint stars.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Optics / Scale" />
                            <TextBlock TextWrapping="Wrap">
                                Focal length and pixel size affect pixel scale and solver performance.
                                Prefer using pixel size from the camera profile if possible.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Solver" />
                            <TextBlock TextWrapping="Wrap">
                                A larger search radius increases tolerance but slows solving.
                                Downsample 2 is usually a good compromise.
                                Timeout protects against solver stalls.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Offset" />
                            <TextBlock TextWrapping="Wrap">
                                The currently calibrated offset can be viewed here.
                                The offset must be reset before recalibration.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HelpCard}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Local API (Touch-N-Stars)" />
                            <TextBlock TextWrapping="Wrap">
                                Enables a local HTTP server (localhost).
                                Change the port if there are conflicts.
                                Only enable token protection if access needs to be secured.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!--
                        =========================
                        OAG Camera Autofocus
                        =========================
                    -->

                    <GroupBox Margin="0,10,0,0" Header="OAG Autofocus">
                        <StackPanel>
                            <CheckBox
                                Margin="0,0,0,10"
                                Content="Show AF block in Camera UI"
                                IsChecked="{Binding Settings.AFBlock, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Shows/hides the Autofocus (AFBlock) section in the Camera dockable." />

                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Capture" />

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="150" Text="Exposure (s)" />
                                <TextBox Width="80" Text="{Binding Settings.AfExposureSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="150" Text="Gain" />
                                <TextBox Width="80" Text="{Binding Settings.AfGain, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="150" Text="Bin X / Y" />
                                <TextBox
                                    Width="38"
                                    Margin="0,0,6,0"
                                    Text="{Binding Settings.AfBinX, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Width="38" Text="{Binding Settings.AfBinY, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Separator Margin="0,8,0,8" />

                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Focus sweep" />

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="150" Text="Step size" />
                                <TextBox Width="80" Text="{Binding Settings.AfStepSize, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="150" Text="Steps out / in" />
                                <TextBox
                                    Width="38"
                                    Margin="0,0,6,0"
                                    Text="{Binding Settings.AfStepsOut, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Width="38" Text="{Binding Settings.AfStepsIn, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Separator Margin="0,8,0,8" />

                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Backlash" />

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="150" Text="Backlash steps" />
                                <TextBox Width="80" Text="{Binding Settings.AfBacklashSteps, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="150" Text="Mode" />
                                <ComboBox
                                    Width="200"
                                    SelectedValue="{Binding Settings.AfBacklashMode, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Tag">
                                    <ComboBoxItem Content="None" Tag="{x:Static psp:BacklashMode.None}" />
                                    <ComboBoxItem Content="Overshoot + Return" Tag="{x:Static psp:BacklashMode.OvershootReturn}" />
                                    <ComboBoxItem Content="One-way approach" Tag="{x:Static psp:BacklashMode.OneWayApproach}" />
                                </ComboBox>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                </StackPanel>

            </Grid>
        </ScrollViewer>
    </DataTemplate>
</ResourceDictionary>
