<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:seq="clr-namespace:NINA.Plugins.PlateSolvePlus.PlatesolveplusSequenceItems"
                    xmlns:view="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer">

    <Style x:Key="SectionCard" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#22000000" />
        <Setter Property="Background" Value="#08000000" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,10,8" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="Opacity" Value="0.72" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <DataTemplate DataType="{x:Type seq:PlatesolveplusWaitUntilReadyInstruction}">
        <view:SequenceBlockView>
            <view:SequenceBlockView.SequenceItemContent>
                <StackPanel>
                    <TextBlock Margin="0,0,0,12"
                               Style="{StaticResource HintText}"
                               Text="Pauses the sequence until PlateSolvePlus is imported, idle and ready for the next action." />

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Readiness Check" />
                            <TextBlock Margin="0,4,0,10" Style="{StaticResource HintText}" Text="Useful before a solve, centering pass or autofocus step when you want the sequencer to wait for the plugin to settle down first." />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Timeout (s)" />
                                <TextBox Grid.Column="1" Text="{Binding TimeoutSeconds, UpdateSourceTrigger=LostFocus}" />

                                <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="Poll interval (ms)" />
                                <TextBox Grid.Column="4" Text="{Binding PollIntervalMs, UpdateSourceTrigger=LostFocus}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </view:SequenceBlockView.SequenceItemContent>
        </view:SequenceBlockView>
    </DataTemplate>

</ResourceDictionary>