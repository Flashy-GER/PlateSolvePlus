<Window
    x:Class="NINA.Plugins.PlateSolvePlus.SecondaryAutofocus.Plot.AutofocusPlotWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:oxy="http://oxyplot.org/wpf"
    Title="Secondary Autofocus"
    Width="820"
    Height="520"
    Topmost="True"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="8"
            BorderThickness="1"
            CornerRadius="6">
            <TextBlock FontSize="14" Text="{Binding StatusLine}" />
        </Border>

        <oxy:PlotView
            Grid.Row="1"
            Margin="0,10,0,0"
            Model="{Binding Model}" />
    </Grid>
</Window>
