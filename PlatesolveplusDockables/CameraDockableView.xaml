<UserControl x:Class="NINA.Plugins.PlateSolvePlus.PlatesolveplusDockables.CameraDockableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="520">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header / Status -->
            <RowDefinition Height="Auto"/>  <!-- Camera selection / buttons -->
            <RowDefinition Height="*"/>     <!-- Two-column content area -->
        </Grid.RowDefinitions>

        <!-- =========================
             Header / Status
             ========================= -->
        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="#22000000"
                Background="#0A000000"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding StatusText}"
                           FontWeight="SemiBold"
                           FontSize="14"/>

                <!-- Details are multi-line (RA/Dec, deltas, hints). Use a readonly TextBox to preserve formatting. -->
                <TextBox Text="{Binding DetailsText}"
                         Margin="0,6,0,0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="72"/>
            </StackPanel>
        </Border>

        <!-- =========================
             Secondary Camera + Buttons
             ========================= -->
        <GroupBox Grid.Row="1" Header="Sekundärkamera / Aktionen" Margin="0,0,0,10">
            <StackPanel Margin="10">

                <TextBlock Text="Kamera auswählen:" Margin="0,0,0,4" Opacity="0.85"/>
                <ComboBox ItemsSource="{Binding SecondaryCameraDevices}"
                          SelectedItem="{Binding SelectedSecondaryCamera}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,10"/>

                <WrapPanel Margin="0,0,0,10">
                    <Button Content="ASCOM neu suchen"
                            Width="120"
                            Margin="0,0,8,8"
                            Command="{Binding RefreshSecondaryCameraListCommand}"/>

                    <Button Content="Treiber-Einstellungen"
                            Width="120"
                            Margin="0,0,8,8"
                            Command="{Binding OpenDriverSettingsCommand}"/>

                    <Button Content="Verbinden"
                            Width="90"
                            Margin="0,0,8,8"
                            Command="{Binding ConnectSecondaryCommand}"/>

                    <Button Content="Trennen"
                            Width="90"
                            Margin="0,0,8,8"
                            Command="{Binding DisconnectSecondaryCommand}"/>

                    <!-- Capture only -->
                    <Button Content="Capture Only"
                            Width="110"
                            Margin="0,0,8,8"
                            Command="{Binding CaptureOnlyCommand}"
                            IsEnabled="{Binding CanCaptureOnly}"/>

                    <!-- Capture + Sync/Slew -->
                    <Button Content="{Binding CaptureAndSolveButtonText}"
                            Width="140"
                            Margin="0,0,8,8"
                            Command="{Binding CaptureAndSolveCommand}"
                            IsEnabled="{Binding CanCaptureAndSolveAction}"/>

                    <Button Content="Offset kalibrieren"
                            Width="140"
                            Margin="0,0,8,8"
                            Command="{Binding CalibrateOffsetCommand}"
                            IsEnabled="{Binding CanCalibrateOffset}"/>
                </WrapPanel>

                <CheckBox Content="Capture + Slew (Center) statt Capture + Sync"
                          IsChecked="{Binding UseSlewInsteadOfSync}"
                          Margin="0,0,0,10"/>


                <!-- Target (main) for: Slew to Target + Center -->
                <GroupBox Header="Target (Main, Grad)" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBlock Text="Koordinaten in Grad (Main-Sky)."
                                   Opacity="0.75"
                                   Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="RA°" Width="40" VerticalAlignment="Center"/>
                            <TextBox Width="120"
                                     Text="{Binding TargetRaDeg, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.######}}"
                                     ToolTip="Rektaszension in Grad (0..360)"/>
                            <TextBlock Text="Dec°" Width="50" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            <TextBox Width="120"
                                     Text="{Binding TargetDecDeg, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.######}}"
                                     ToolTip="Deklination in Grad (-90..+90)"/>
                        </StackPanel>

                        <Button Content="Zum Target slewen + Center"
                                Width="200"
                                Command="{Binding SlewToTargetAndCenterCommand}"
                                IsEnabled="{Binding CanSlewToTargetAndCenter}"
                                ToolTip="Slew zum Target und anschließend Center (Sekundärkamera + Offset-Mapping)."/>
                    </StackPanel>
                </GroupBox>

                <Separator Margin="0,0,0,10"/>

                <TextBlock Text="{Binding MountStatusText}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <TextBlock Text="{Binding MountDetailsText}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>

                <TextBlock Text="{Binding OffsetStatusText}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- =========================
             Two-column content area
             Left: Solve + Settings
             Right: Image Preview (Solved Image)
             ========================= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,10,0">
                <StackPanel>

                    <!-- Solve Output -->
                    <GroupBox Header="Ergebnisse" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <TextBlock Text="Platesolve"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <!-- 1) Last guider solve text -->
                            <TextBlock Text="{Binding LastGuiderSolveText}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Korrigiert (Offset)"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,6"/>

                            <!-- 2) corrected coordinates after offset -->
                            <TextBlock Text="{Binding CorrectedSolveText}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       Margin="0,0,0,8"/>

                            <Separator Margin="0,4,0,8"/>

                            <TextBlock Text="Solver-Details"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <!-- 3) Last solve result (raw / summary) -->
                            <TextBox Text="{Binding LastSolveSummary}"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     Height="130"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Readonly camera settings -->
                    <GroupBox Header="Kamera-Einstellungen (read-only)" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Exposure (sec)" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GuideExposureSeconds}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Gain (-1 = Auto)" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GuideGain}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Binning" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GuideBinning}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Focal Length (mm)" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GuideFocalLengthMm}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Pixel Size (µm)" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding GuidePixelSizeUm}"/>
                        </Grid>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT COLUMN: Image Preview -->
            <GroupBox Grid.Column="1" Header="Bildvorschau (Solved)">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview options (rendering happens in VM/service) -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Darstellung" Margin="0,0,12,0" Opacity="0.75"/>

                        <CheckBox Content="Auto Stretch"
                                  IsChecked="{Binding PreviewAutoStretchEnabled}"
                                  ToolTip="Auto Stretch wird im ViewModel/Service gerendert."/>
                    </WrapPanel>

                    <Border Grid.Row="1"
                            BorderThickness="1"
                            BorderBrush="#33000000"
                            CornerRadius="4"
                            Padding="6">
                        <Grid>
                            <!-- Background placeholder feel -->
                            <Border Background="#08000000"/>

                            <Image Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <PriorityBinding>
                                        <Binding Path="CapturedFrame"/>
                                        <Binding Path="LastCapturedImage"/>
                                    </PriorityBinding>
                                </Image.Source>
                            </Image>

                            <!-- No image hint -->
                            <TextBlock Text="Vorschau nicht verfügbar"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.55"
                                       FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding SolvedPreviewImage}" Value="{x:Null}"/>
                                                    <Condition Binding="{Binding LastCapturedImage}" Value="{x:Null}"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2"
                               Margin="0,8,0,0"
                               Text="{Binding PreviewInfoText}"
                               Opacity="0.8"/>
                </Grid>
            </GroupBox>

        </Grid>

    </Grid>
</UserControl>
