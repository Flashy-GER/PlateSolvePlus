<UserControl x:Class="NINA.Plugins.PlateSolvePlus.PlatesolveplusDockables.CameraDockableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="520">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- =========================
             Header / Status
             ========================= -->
        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="#22000000"
                Background="#0A000000"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding StatusText}"
                           FontWeight="SemiBold"
                           FontSize="14"/>

                <TextBox Text="{Binding DetailsText}"
                         Margin="0,6,0,0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="72"/>
            </StackPanel>
        </Border>

        <!-- =========================
             Secondary Camera + Actions
             ========================= -->
        <GroupBox Grid.Row="1" Header="Secondary Camera / Actions" Margin="0,0,0,10">
            <StackPanel Margin="10">

                <TextBlock Text="Select camera:" Margin="0,0,0,4" Opacity="0.85"/>
                <ComboBox ItemsSource="{Binding SecondaryCameraDevices}"
                          SelectedItem="{Binding SelectedSecondaryCamera}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,10"/>

                <WrapPanel Margin="0,0,0,10">
                    <Button Content="Rescan ASCOM"
                            Width="120"
                            Margin="0,0,8,8"
                            Command="{Binding RefreshSecondaryCameraListCommand}"/>

                    <Button Content="Driver Settings"
                            Width="120"
                            Margin="0,0,8,8"
                            Command="{Binding OpenDriverSettingsCommand}"/>

                    <Button Content="Connect"
                            Width="90"
                            Margin="0,0,8,8"
                            Command="{Binding ConnectSecondaryCommand}"/>

                    <Button Content="Disconnect"
                            Width="90"
                            Margin="0,0,8,8"
                            Command="{Binding DisconnectSecondaryCommand}"/>

                    <Button Content="Capture Only"
                            Width="110"
                            Margin="0,0,8,8"
                            Command="{Binding CaptureOnlyCommand}"
                            IsEnabled="{Binding CanCaptureOnly}"/>

                    <Button Content="{Binding CaptureAndSolveButtonText}"
                            Width="140"
                            Margin="0,0,8,8"
                            Command="{Binding CaptureAndSolveCommand}"
                            IsEnabled="{Binding CanCaptureAndSolveAction}"/>

                    <Button Content="Calibrate Offset"
                            Width="140"
                            Margin="0,0,8,8"
                            Command="{Binding CalibrateOffsetCommand}"
                            IsEnabled="{Binding CanCalibrateOffset}"/>
                </WrapPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- the switch -->
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding UseSlewInsteadOfSync}"
                              VerticalAlignment="Center"/>

                    <!-- the label text -->
                    <TextBlock Grid.Column="2"
                               Text="Use Capture + Slew (Center) instead of Capture + Sync"
                               Opacity="0.85"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Grid>


                <!-- Target (main) for: Slew to Target + Center -->
                <GroupBox Header="Target (Main, Degrees)" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBlock Text="Coordinates in degrees (main sky)."
                                   Opacity="0.75"
                                   Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="RA°" Width="40" VerticalAlignment="Center"/>
                    <TextBox Width="120"
                             Style="{x:Null}"
                             Text="{Binding TargetRaDeg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Right ascension in degrees (0..360)"/>

                    <TextBox Width="120"
                             Style="{x:Null}"
                             Text="{Binding TargetDecDeg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Declination in degrees (-90..+90)"/>
                </StackPanel>

                <!-- debug line: remove later -->
                <TextBlock Text="{Binding TargetRaDeg, FallbackValue=NO_DC}"
                           Opacity="0.5"
                           FontFamily="Consolas"/>

                        <Button Content="Slew to target + center"
                                Width="200"
                                Command="{Binding SlewToTargetAndCenterCommand}"
                                IsEnabled="{Binding CanSlewToTargetAndCenter}"
                                ToolTip="Slew to the target and then center using the secondary camera and offset mapping."/>
                    </StackPanel>
                </GroupBox>

                <Separator Margin="0,0,0,10"/>

                <TextBlock Text="{Binding MountStatusText}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <TextBlock Text="{Binding MountDetailsText}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>

                <TextBlock Text="{Binding OffsetStatusText}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- =========================
             Two-column content area
             ========================= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,10,0">
                <StackPanel>

                    <GroupBox Header="Results" Margin="0,0,0,10">
                        <StackPanel Margin="10">

                            <TextBlock Text="Plate Solve"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding LastGuiderSolveText}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Corrected (Offset)"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,6"/>

                            <TextBlock Text="{Binding CorrectedSolveText}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       Margin="0,0,0,8"/>

                            <Separator Margin="0,4,0,8"/>

                            <TextBlock Text="Solver Details"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <TextBox Text="{Binding LastSolveSummary}"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     Height="130"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Camera Settings (read-only)" Margin="0,0,0,10">
                        <Grid Margin="10">

                            <!-- Columns -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Rows -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Exposure -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Exposure (sec)"
                                       Opacity="0.8"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding GuideExposureSeconds}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <!-- Gain -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Gain (-1 = Auto)"
                                       Opacity="0.8"
                                       Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding GuideGain}"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>

                            <!-- Binning -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Binning"
                                       Opacity="0.8"
                                       Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding GuideBinning}"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>

                            <!-- Focal length -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Focal Length (mm)"
                                       Opacity="0.8"
                                       Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding GuideFocalLengthMm}"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>

                            <!-- Pixel size -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Pixel Size (µm)"
                                       Opacity="0.8"
                                       Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding GuidePixelSizeUm}"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>

                        </Grid>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT COLUMN -->
            <GroupBox Grid.Column="1" Header="Image Preview (Solved)">
                <Grid Margin="10">

                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="Rendering" Margin="0,0,12,0" Opacity="0.75"/>
                        <CheckBox Content="Auto Stretch"
                                  IsChecked="{Binding PreviewAutoStretchEnabled}"
                                  ToolTip="Auto stretch is rendered in the ViewModel/service."/>
                    </WrapPanel>

                    <Border BorderThickness="1"
                            BorderBrush="#33000000"
                            CornerRadius="4"
                            Padding="6">
                        <Grid>
                            <Border Background="#08000000"/>

                            <Image Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <PriorityBinding>
                                        <Binding Path="CapturedFrame"/>
                                        <Binding Path="LastCapturedImage"/>
                                    </PriorityBinding>
                                </Image.Source>
                            </Image>

                            <TextBlock Text="Preview not available"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.55"
                                       FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding SolvedPreviewImage}" Value="{x:Null}"/>
                                                    <Condition Binding="{Binding LastCapturedImage}" Value="{x:Null}"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding PreviewInfoText}"
                               Opacity="0.8"/>
                </Grid>
            </GroupBox>

        </Grid>
    </Grid>
</UserControl>
